<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" 
 "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<!-- mapperインターフェスと修飾名を一致させる -->
<mapper
	namespace="jp.co.sss.equipment.mapper.BorrowingHistoryMapper">
	<!-- DTOマッピング -->
	<resultMap id="BorrowingHistoryResultMap"
		type="jp.co.sss.equipment.dto.BorrowingHistoryDto">

		<result column="stock_code" property="stockCode" />
		<result column="category_name" property="categoryName" />
		<result column="product_name" property="productName" />
		<result column="staffName" property="staffName" />
		<result column="start_date" property="startDate" />
		<result column="return_date" property="returnDate" />
		<result column="limit_date" property="limitDate" />
		<result column="ownership_type" property="ownershipType" />
		<result column="deleted_label" property="deletedLabel" />

	</resultMap>

	<!-- 履歴取得 -->
	<!-- 履歴取得 -->
	<select id="findBorrowingHistory"
		parameterType="jp.co.sss.equipment.form.BorrowingHistorySearchForm"
		resultMap="BorrowingHistoryResultMap">

		SELECT
		stock_code,
		category_name,
		product_name,
		staffName,
		start_date,
		return_date,
		limit_date,
		ownership_type,
		deleted_label
		FROM borrow_history_view

		<where>
			<if test="stockCode != null and stockCode != ''">
				AND stock_code LIKE CONCAT('%', #{stockCode}, '%')
			</if>

			<if test="categoryName != null and categoryName != ''">
				AND category_name LIKE CONCAT('%', #{categoryName}, '%')
			</if>

			<if test="productName != null and productName != ''">
				AND product_name LIKE CONCAT('%', #{productName}, '%')
			</if>

			<if test="staffNo != null">
				AND staff_no = #{staffNo}
			</if>

			<if test="fromDate != null">
				AND start_date &gt;= #{fromDate}
			</if>

			<if test="toDate != null">
				AND start_date &lt;= #{toDate}
			</if>

			<if test="ownershipType != null and ownershipType != ''">
				AND ownership_type = #{ownershipType}
			</if>

			<if test="includeDeleted != null and includeDeleted == false">
				AND (deleted_label IS NULL OR deleted_label = '')
			</if>
		</where>

		ORDER BY start_date DESC

	</select>

</mapper>